#include "codexion.h"



unsigned long ft_gettime_ms()
{
	struct timeval new;
	gettimeofday(&new, NULL);
	return (new.tv_sec * 1000) + (new.tv_usec / 1000);
}

unsigned long ft_gettime(unsigned long time_create_coder)
{
	struct timeval new;
	gettimeofday(&new, NULL);
	return (new.tv_sec * 1000) + (new.tv_usec / 1000) - time_create_coder;
}


void ft_compile(t_coder *coder, long time_ms)
{
	pthread_mutex_lock(&coder->left->mutex);
	usleep((unsigned int)time_ms * 1000);
	printf("%ld %d is compeling \n", ft_gettime_ms(coder->time_create), coder->id);
	pthread_mutex_unlock(&coder->left->mutex);
}

void ft_debug(t_coder *coder)
{
	printf("%d is debugging\n", coder->id);
}

void ft_refactor(t_coder *coder)
{
	printf("%d is refactoring\n", coder->id);
}

void *rotune(void *arg)
{
	t_coder *coder = (t_coder *)arg;
	while(1)
	{
		ft_compile(coder, coder->time_of_compile);
//		ft_debug(coder);
//		ft_refactor(coder);
	}
	return NULL;
}




void ft_create_threads(t_config config)
{
	t_dongle *dongle = (t_dongle *)malloc(sizeof(t_dongle) * config.number_of_coders);
	t_coder *coders = (t_coder *)malloc(sizeof(t_coder) * config.number_of_coders);

	for (int i = 0; i < config.number_of_coders; i++)
	{
		coders[i].id = i;
		pthread_mutex_init(&dongle[i].mutex, NULL);
		coders[i].left = &dongle[i];
		coders[i].time_compile = config.time_to_compile;
		coders[i].right = &dongle[(i + 1) / config.number_of_coders];
	}
	int  i;
	i = 0;
	while (config.number_of_coders > i)
	{
		pthread_create(&coders[i].th, NULL, rotune, &coders[i]);
		pthread_mutex_lock(&coders[i].left->mutex);
		coders[i].time_create = ft_gettime_ms();
		pthread_mutex_unlock(&coders[i].left->mutex);
		coders->number_compiles = config.number_of_compiles_required;
		i++;
	}
	i = 0;
	while(config.number_of_coders > i)
	{
		pthread_join(coders[i].th, NULL);
		i++;
	}
}



int main(int ac, char **argv)
{
	t_config config;
	if(parse_args(ac, argv, &config))
		return (1);
	ft_create_threads(config);
}
